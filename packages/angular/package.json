{
  "name": "@infobloxopen/devedge-ufe-angular",
  "version": "0.1.3",
  "description": "Angular glue (plain TS) for the devedge-ufe SessionProvider seam: InjectionToken, provider fn, and functional bearer interceptor. Angular 15..latest.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/infobloxopen/devedge-ufe-sdk.git",
    "directory": "packages/angular"
  },
  "homepage": "https://github.com/infobloxopen/devedge-ufe-sdk/tree/main/packages/angular#readme",
  "bugs": {
    "url": "https://github.com/infobloxopen/devedge-ufe-sdk/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@angular/core": ">=15",
    "@angular/common": ">=15",
    "rxjs": ">=7"
  },
  "dependencies": {
    "@infobloxopen/devedge-ufe-core": "workspace:*"
  },
  "devDependencies": {
    "@angular/core": "^15.2.10",
    "@angular/common": "^20.3.25",
    "@angular/compiler": "^15.2.10",
    "rxjs": "^7.8.0",
    "zone.js": "~0.13.3",
    "typescript": "^5.4.0",
    "vitest": "^3.2.6",
    "jsdom": "^24.0.0"
  }
}
