{
  "name": "@infobloxopen/devedge-ufe-oidc",
  "version": "0.1.3",
  "description": "Generic OIDC (authorization-code + PKCE) binding for the devedge-ufe SessionProvider seam. Provider-agnostic; no identity provider hardwired.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/infobloxopen/devedge-ufe-sdk.git",
    "directory": "packages/oidc"
  },
  "homepage": "https://github.com/infobloxopen/devedge-ufe-sdk/tree/main/packages/oidc#readme",
  "bugs": {
    "url": "https://github.com/infobloxopen/devedge-ufe-sdk/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "oidc-client-ts": "^3.1.0",
    "@infobloxopen/devedge-ufe-core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^3.2.6",
    "jsdom": "^24.0.0"
  }
}
