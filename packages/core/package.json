{
  "name": "@infobloxopen/devedge-ufe-core",
  "version": "0.1.2",
  "description": "Mechanism-only micro-frontend contract for devedge: lifecycle, loud nav-group validation, session seam, and manifest types. Zero runtime dependencies.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/infobloxopen/devedge-ufe-sdk.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/infobloxopen/devedge-ufe-sdk/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/infobloxopen/devedge-ufe-sdk/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^3.2.6",
    "jsdom": "^24.0.0"
  }
}
