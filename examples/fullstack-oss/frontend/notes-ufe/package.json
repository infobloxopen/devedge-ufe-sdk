{
  "name": "csp-notes-ufe-ufe",
  "version": "0.1.0",
  "description": "Notes-ufe micro-frontend — Angular 15 + single-spa, wired to the devedge-ufe SDK.",
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "build": "ng build",
    "start": "ng serve",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "test": "ng test",
    "doctor": "devedge-ufe doctor --url https://localhost:4200 --app notes-ufe --metadata metadata.js"
  },
  "dependencies": {
    "@angular/animations": "~15.2.0",
    "@angular/common": "~15.2.0",
    "@angular/compiler": "~15.2.0",
    "@angular/core": "~15.2.0",
    "@angular/forms": "~15.2.0",
    "@angular/platform-browser": "~15.2.0",
    "@angular/platform-browser-dynamic": "~15.2.0",
    "@angular/router": "~15.2.0",
    "@angular/cdk": "~15.2.0",
    "@angular/material": "~15.2.0",
    "@infobloxopen/devedge-ufe-core": "file:../../../../packages/core",
    "@infobloxopen/devedge-ufe-angular": "file:../../../../packages/angular",
    "@infobloxopen/devedge-ufe-single-spa": "file:../../../../packages/single-spa",
    "@infobloxopen/devedge-ufe-oidc": "file:../../../../packages/oidc",
    "@infobloxopen/devedge-ufe-dev-loop": "file:../../../../packages/dev-loop",
    "@example/notesd-client": "file:../../clients/notesd-client",
    "single-spa": "^6.0.0",
    "single-spa-angular": "^8.0.0",
    "systemjs-webpack-interop": "^2.3.7",
    "core-js": "^3.36.0",
    "rxjs": "^7.8.0",
    "tslib": "^2.6.0",
    "zone.js": "^0.12.0"
  },
  "devDependencies": {
    "@angular-builders/custom-webpack": "^15.0.0",
    "@angular-devkit/build-angular": "~15.2.0",
    "@angular/cli": "~15.2.0",
    "@angular/compiler-cli": "~15.2.0",
    "typescript": "~4.9.5",
    "webpack": "^5.90.0",
    "webpack-merge": "^5.10.0",
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "jest-preset-angular": "^13.1.4"
  },
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "//": "The local SDK packages declare their internal dep on -core as 'workspace:*'. Outside the SDK's own pnpm workspace (this example installs standalone via --ignore-workspace) that specifier cannot resolve, so we override it to the same local path the SDK is linked from. When installing from npm this override is unnecessary and can be dropped.",
    "overrides": {
      "@infobloxopen/devedge-ufe-core": "file:../../../../packages/core"
    }
  }
}
